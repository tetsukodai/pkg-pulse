{
  "name": "@tetsukod.ai/pkg-pulse",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "CLI tool that scores npm package health across six weighted categories",
  "bin": {
    "pkg-pulse": "./dist/bin/index.js"
  },
  "engines": {
